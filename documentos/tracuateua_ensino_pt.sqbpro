SELECT * 
FROM arvores;


SELECT *
FROM especies;


SELECT COUNT(*) 
FROM arvores;


SELECT AVG(altura_m) 
FROM arvores;

SELECT *
FROM parcelas;


SELECT 
    a.id_arvore,
    e.nome_cientifico,
    a.altura_m
FROM arvores a
JOIN especies e ON a.id_especie = e.id_especie;</sql><current_tab id="0"/></tab_sql></sqlb_project>
